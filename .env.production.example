# Infinity Hotel PMS production environment
# Copy to .env.production on the VPS, fill in real values, then run npm run build.

NODE_ENV=production
PORT=3000
SITE_URL=https://your-domain.com

# Supabase project settings from the new Supabase account.
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vite embeds these values into the browser bundle at build time.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Protect scheduled public hook endpoints.
CRON_SECRET=

# Optional integrations. Leave blank until configured.
PRINTNODE_API_KEY=
VIRUSTOTAL_API_KEY=
BOOKING_COM_WEBHOOK_SECRET=
RESEND_API_KEY=
ANALYTICS_EMAIL_FROM=
LOVABLE_API_KEY=

# Test harness must remain disabled in production.
TEST_HARNESS_ENABLED=0
TEST_HARNESS_SECRET=
